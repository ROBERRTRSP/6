# Frontend (Vercel)
# If the API is deployed on another host, set this in Vercel.
VITE_API_BASE=
# Optional local fallback when frontend and API run in different ports
VITE_API_PORT=43778

# Public URL used to generate player QR links.
# Example: https://your-vercel-app.vercel.app
PUBLIC_KIOSK_URL=

# Backend server
NODE_ENV=production
PORT=43778
CORS_ORIGIN=
SESSION_SECRET=
ADMIN_USER=admin
ADMIN_PASSWORD=

# Local SQLite fallback used by the current backend.
DATABASE_PATH=server/data/lucky-six.db

# Neon PostgreSQL target for the production migration.
# NOTE: The current runtime still uses SQLite until the DB adapter is migrated.
DATABASE_URL=
